{
  "name": "epure-workspace",
  "version": "1.0.0",
  "description": "Épure - Image Processing App (Workspace)",
  "private": true,
  "workspaces": [
    "desktop-app",
    "website",
    "webhook-server"
  ],
  "scripts": {
    "start": "cd webhook-server && npm start",
    "dev": "cd webhook-server && npm run dev",
    "build": "cd webhook-server && npm ci --production",
    "postinstall": "cd webhook-server && npm install",
    "desktop:dev": "cd desktop-app && npm run dev",
    "desktop:build": "cd desktop-app && npm run build",
    "website:start": "cd website && npm start",
    "website:dev": "cd website && npm start",
    "install:all": "npm install && cd desktop-app && npm install && cd ../website && npm install && cd ../webhook-server && npm install",
    "clean": "rm -rf node_modules desktop-app/node_modules website/node_modules webhook-server/node_modules desktop-app/dist"
  },
  "keywords": [
    "electron",
    "image-processing",
    "desktop-app",
    "workspace"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {},
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
