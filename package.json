{
  "name": "limye",
  "productName": "Limyè",
  "version": "1.0.0",
  "description": "A minimalist image processing app for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac"
  },
  "keywords": [
    "electron",
    "image",
    "processing",
    "sharp",
    "resize",
    "converter",
    "macos"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.0.12",
    "electron-store": "^8.1.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.limye.app",
    "productName": "Limyè",
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "files": [
      "**/*",
      "!.git{,/**}"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/R2Ace/imageAppDesk.git"
  },
  "bugs": {
    "url": "https://github.com/R2Ace/imageAppDesk/issues"
  },
  "homepage": "https://github.com/R2Ace/imageAppDesk#readme"
}
