{
  "name": "epure-workspace",
  "version": "1.0.0",
  "description": "Épure - Image Processing App (Workspace)",
  "private": true,
  "workspaces": [
    "desktop-app",
    "website"
  ],
  "scripts": {
    "start": "cd desktop-app && npm start",
    "dev": "cd desktop-app && npm run dev",
    "build": "cd desktop-app && npm run build",
    "build:mac": "cd desktop-app && npm run build:mac",
    "build:dmg": "cd desktop-app && npm run build:dmg",
    "website:start": "cd website && npm start",
    "website:dev": "cd website && npm start",
    "install:all": "npm install && cd desktop-app && npm install && cd ../website && npm install",
    "clean": "rm -rf node_modules desktop-app/node_modules website/node_modules desktop-app/dist"
  },
  "keywords": [
    "electron",
    "image-processing",
    "desktop-app",
    "workspace"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {},
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
